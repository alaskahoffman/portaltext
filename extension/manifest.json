{
  "manifest_version": 3,
  "name": "portaltext",
  "version": "0.3.0",
  "description": "AI tooltips for every link. Hover anything \u2014 articles, PDFs, citations \u2014 for a context-aware summary. Free, no account needed.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "portaltext",
    "default_icon": {
      "16": "assets/portalcatmini16.png",
      "48": "assets/portalcatmini48.png",
      "128": "assets/portalcatmini128.png"
    }
  },
  "icons": {
    "16": "assets/portalcatmini16.png",
    "48": "assets/portalcatmini48.png",
    "128": "assets/portalcatmini128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.svg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}