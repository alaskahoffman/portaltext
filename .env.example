# portaltext server configuration. Copy to .env for local dev (`npm run dev`
# auto-loads it); in production set these in your host's environment instead.
# Names only — never commit a real .env.

# --- Model providers ---------------------------------------------------------
# Required. Anthropic is the fallback provider and handles PDFs (document
# blocks) and page annotation regardless of MODEL_PROVIDER.
ANTHROPIC_API_KEY=sk-ant-...

# Active provider for tooltip summaries: anthropic | openrouter | together
MODEL_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=qwen/qwen3.6-plus
# Per-million-token pricing for cost logging when the model isn't in the
# built-in table (lets you swap models via env alone).
#OPENROUTER_INPUT_PRICE=0.325
#OPENROUTER_OUTPUT_PRICE=1.95
#TOGETHER_API_KEY=
#TOGETHER_MODEL=
#TOGETHER_INPUT_PRICE=
#TOGETHER_OUTPUT_PRICE=

# --- Cost control ------------------------------------------------------------
# Hard ceiling on model spend per UTC day (USD). When tripped, free/anon
# requests pause until tomorrow; funded tiers keep working. 0 disables.
DAILY_SPEND_CAP_USD=10

# --- Deployment ---------------------------------------------------------------
PORT=3000
# Number of trusted reverse proxies in front of the app. Client IPs are read
# from X-Forwarded-For at this depth from the right. Direct exposure = 0;
# one platform proxy (Render/Railway/Fly) = 1; Cloudflare + platform = 2.
# Getting this wrong either lets clients spoof rate-limit buckets or lumps
# everyone into one bucket.
TRUSTED_PROXY_HOPS=1
# Comma-separated CORS allowlist; * for open.
#ALLOWED_ORIGINS=*

# --- Storage -----------------------------------------------------------------
# SQLite account DB. Point at a persistent disk in production — losing this
# file loses all accounts and quota state.
#AUTH_DB_PATH=/var/data/portaltext.db
# Append-only per-call usage log (also seeds the spend breaker on boot).
#TOKEN_USAGE_LOG=/var/data/token-usage.jsonl
